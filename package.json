{
  "name": "grizzly-sms-desktop",
  "version": "0.3.1",
  "description": "A secure Windows desktop client for Grizzly SMS",
  "main": "electron/main.cjs",
  "type": "module",
  "author": "Grizzly SMS Desktop Contributors",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "build": "tsc --noEmit && vite build",
    "test": "node --test test/*.test.cjs",
    "preview": "vite preview",
    "start": "electron .",
    "dist": "npm run build && electron-builder --win nsis",
    "dist:portable": "npm run build && electron-builder --win portable"
  },
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.2",
    "concurrently": "^9.2.1",
    "electron": "^37.4.0",
    "electron-builder": "^26.0.12",
    "playwright-core": "^1.61.1",
    "typescript": "^5.9.2",
    "vite": "^7.1.4",
    "wait-on": "^8.0.4"
  },
  "build": {
    "appId": "com.grizzlysms.desktop",
    "productName": "Grizzly SMS Desktop",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "THIRD_PARTY_NOTICES.md"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-${version}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
